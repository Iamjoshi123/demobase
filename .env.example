# Database
DATABASE_URL=sqlite:///./agentic_demo_brain.db

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=demo_brain

# LiveKit (voice sessions)
# Local Docker example:
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=devsecret0123456789devsecret0123456789
#
# LiveKit Cloud example:
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-project-api-key
# LIVEKIT_API_SECRET=your-project-api-secret
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret0123456789devsecret0123456789

# LLM providers (optional - falls back to Ollama if unset)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434

# Encryption key for credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Browser automation
PLAYWRIGHT_HEADLESS=true
ENABLE_BROWSER_USE_FALLBACK=false
ENABLE_STAGEHAND=false
STAGEHAND_SERVER_MODE=bridge
STAGEHAND_MODEL_NAME=openai/gpt-4.1-mini
STAGEHAND_CDP_PORT=9222
STAGEHAND_BRIDGE_URL=http://127.0.0.1:4545

# Voice
ENABLE_VOICE=false
VOICE_PROVIDER=local
VOICE_WHISPER_MODEL=base.en
VOICE_LANGUAGE=en
VOICE_MIN_TRANSCRIPT_CHARS=2
VOICE_TTS_PROVIDER=auto
VOICE_TTS_VOICE=en-US-AriaNeural
VOICE_TRANSCRIPT_DEBUG=false
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_SILENCE_MS=280

# Sandbox defaults
DEFAULT_ALLOWED_DOMAIN=localhost
SESSION_TIMEOUT_SECONDS=1800

# App
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
