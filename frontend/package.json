{
  "name": "agentic-demo-brain-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "next build --no-lint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run src/app/admin/page.test.tsx src/app/admin/workspaces/[id]/page.test.tsx src/app/admin/workspaces/[id]/sessions/page.test.tsx src/app/demo/[token]/page.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:acceptance": "npm run build && playwright test -g \"Acceptance Journey\"",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "livekit-client": "^2.15.8",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@playwright/test": "^1.53.2",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
